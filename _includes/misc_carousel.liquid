{% assign carousel_items = "" | split: "" %}
{% if include.key and site.data.misc_images and site.data.misc_images[include.key] %}
  {% assign carousel_items = site.data.misc_images[include.key] %}
{% else %}
  {% assign folder_norm = include.folder | remove_first: "/" %}
  {% assign carousel_items = site.static_files
    | where_exp: "file", "file.path contains folder_norm"
    | where_exp: "file", "file.extname == '.png' or file.extname == '.jpg' or file.extname == '.jpeg' or file.extname == '.webp' or file.extname == '.gif'"
    | sort: "name" %}
{% endif %}

{% if carousel_items and carousel_items.size > 0 %}
  {% assign carousel_id = include.id | default: include.title | slugify %}
  <section class="misc-carousel" data-misc-carousel="{{ carousel_id }}" data-autoplay-ms="{{ include.autoplay_ms | default: 2500 }}">
    <div class="misc-carousel__viewport">
      <div class="misc-carousel__track" aria-live="polite">
        {% for item in carousel_items %}
        {% assign img_path = item.path %}
        {% assign caption = item.caption %}
        {% unless caption %}
          {% assign caption = item.basename | replace: "_", " " | replace: "-", " " %}
        {% endunless %}
        <figure class="misc-carousel__slide{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}">
          <img
            class="misc-carousel__image img-fluid rounded z-depth-1"
              src="{{ img_path | relative_url }}"
              alt="{{ caption }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
            <figcaption class="misc-carousel__caption">{{ caption }}</figcaption>
          </figure>
        {% endfor %}
      </div>

      {% if carousel_items.size > 1 %}
        <button class="misc-carousel__nav misc-carousel__nav--prev" type="button" aria-label="Previous image">&#8249;</button>
        <button class="misc-carousel__nav misc-carousel__nav--next" type="button" aria-label="Next image">&#8250;</button>
      {% endif %}
    </div>

    {% if carousel_items.size > 1 %}
      <div class="misc-carousel__dots" aria-label="Carousel pagination">
        {% for item in carousel_items %}
          {% assign caption = item.caption %}
          {% unless caption %}
            {% assign caption = item.basename | replace: "_", " " | replace: "-", " " %}
          {% endunless %}
          <button
            class="misc-carousel__dot{% if forloop.first %} is-active{% endif %}"
            type="button"
            data-dot-index="{{ forloop.index0 }}"
            aria-label="Show {{ caption }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% endif %}
