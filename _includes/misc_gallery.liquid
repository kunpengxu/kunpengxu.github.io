{% assign gallery_items = "" | split: "" %}
{% if include.key and site.data.misc_images and site.data.misc_images[include.key] %}
  {% assign gallery_items = site.data.misc_images[include.key] %}
{% else %}
  {%- comment -%}
  Fallback for builds that don't run our generator plugin: scan static files.
  Note: some polyglot configurations don't include assets in non-default languages,
  which is why the generator is preferred.
  {%- endcomment -%}
  {% assign folder_norm = include.folder | remove_first: "/" %}
  {% assign gallery_items = site.static_files
    | where_exp: "file", "file.path contains folder_norm"
    | where_exp: "file", "file.extname == '.png' or file.extname == '.jpg' or file.extname == '.jpeg' or file.extname == '.webp' or file.extname == '.gif'"
    | sort: "name" %}
{% endif %}

<section class="misc-section">
  <div class="misc-section__header">
    <h2 class="misc-section__title">{{ include.title }}</h2>
    {% if include.description %}
      <p class="misc-section__description">{{ include.description }}</p>
    {% endif %}
  </div>

  {% if gallery_items and gallery_items.size > 0 %}
    <div class="misc-gallery">
      {% for item in gallery_items %}
        {% assign img_path = item.path %}
        {% assign caption = item.caption %}

        {% unless caption %}
          {% assign base_caption = item.basename %}
          {% assign caption = base_caption | replace: "_", " " | replace: "-", " " %}
        {% endunless %}

        <figure class="misc-gallery__item">
          <img
            class="misc-gallery__image img-fluid rounded z-depth-1"
            src="{{ img_path | relative_url }}"
            alt="{{ caption }}"
            loading="lazy"
          >
          <figcaption class="misc-gallery__caption">{{ caption }}</figcaption>
        </figure>
      {% endfor %}
    </div>
  {% else %}
    <p class="misc-gallery__empty">
      Add images to <code>{{ include.folder }}</code> and they will appear here automatically.
    </p>
  {% endif %}
</section>
