{% assign candidate_files = site.static_files
  | where_exp: "file", "file.path contains include.folder"
  | where_exp: "file", "file.extname == '.png' or file.extname == '.jpg' or file.extname == '.jpeg' or file.extname == '.webp' or file.extname == '.gif'"
  | sort: "name" %}

{% assign widths_desc = "" | split: "" %}
{% assign widths_csv = "" %}
{% if site.imagemagick and site.imagemagick.widths %}
  {% assign widths_desc = site.imagemagick.widths | sort | reverse %}
  {% assign widths_csv = "," | append: (site.imagemagick.widths | join: ",") | append: "," %}
{% endif %}

{%- comment -%}
Jekyll imagemagick can generate responsive images like `name-480.webp`.
On some deploys, only these derivatives are present, which can create duplicates.
We dedupe by logical image key:
- Prefer any non-derivative original (png/jpg/gif/webp without -<width> suffix)
- Otherwise pick the largest derivative available (e.g. 1400.webp)
{%- endcomment -%}

{% assign gallery_files = "" | split: "" %}
{% assign selected_keys = "" | split: "" %}

{%- comment -%}First: select originals (non-derivatives), one per key.{%- endcomment -%}
{% for file in candidate_files %}
  {% assign last_part = file.basename | split: "-" | last %}
  {% assign last_num = last_part | plus: 0 %}
  {% assign last_num_str = last_num | append: "" %}
  {% assign is_derivative = false %}
  {% assign width_marker = "," | append: last_part | append: "," %}
  {% if file.extname == '.webp' and last_num_str == last_part and widths_csv != "" and widths_csv contains width_marker %}
    {% assign is_derivative = true %}
  {% endif %}

  {% unless is_derivative %}
    {% assign key = file.basename %}
    {% unless selected_keys contains key %}
      {% assign selected_keys = selected_keys | push: key %}
      {% assign gallery_files = gallery_files | push: file %}
    {% endunless %}
  {% endunless %}
{% endfor %}

{%- comment -%}Second: for keys that only have derivatives, pick the largest derivative.{%- endcomment -%}
{% assign derivative_keys = "" | split: "" %}
{% for file in candidate_files %}
  {% assign last_part = file.basename | split: "-" | last %}
  {% assign last_num = last_part | plus: 0 %}
  {% assign last_num_str = last_num | append: "" %}
  {% assign is_derivative = false %}
  {% assign width_marker = "," | append: last_part | append: "," %}
  {% if file.extname == '.webp' and last_num_str == last_part and widths_csv != "" and widths_csv contains width_marker %}
    {% assign is_derivative = true %}
  {% endif %}

  {% if is_derivative %}
    {% assign suffix_len = last_part | size | plus: 1 %}
    {% assign key_len = file.basename | size | minus: suffix_len %}
    {% assign key = file.basename | slice: 0, key_len %}
    {% unless selected_keys contains key or derivative_keys contains key %}
      {% assign derivative_keys = derivative_keys | push: key %}
    {% endunless %}
  {% endif %}
{% endfor %}

{% for key in derivative_keys %}
  {% assign found = false %}
  {% for w in widths_desc %}
    {% assign wanted = key | append: "-" | append: w %}
    {% for file in candidate_files %}
      {% if file.extname == '.webp' and file.basename == wanted %}
        {% assign gallery_files = gallery_files | push: file %}
        {% assign found = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% if found %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endfor %}

<section class="misc-section">
  <div class="misc-section__header">
    <h2 class="misc-section__title">{{ include.title }}</h2>
    {% if include.description %}
      <p class="misc-section__description">{{ include.description }}</p>
    {% endif %}
  </div>

  {% if gallery_files.size > 0 %}
    <div class="misc-gallery">
      {% for file in gallery_files %}
        {% assign base_caption = file.basename %}
        {% assign last_part = file.basename | split: "-" | last %}
        {% assign last_num = last_part | plus: 0 %}
        {% assign last_num_str = last_num | append: "" %}
        {% assign width_marker = "," | append: last_part | append: "," %}
        {% if file.extname == '.webp' and last_num_str == last_part and widths_csv != "" and widths_csv contains width_marker %}
          {% assign suffix_len = last_part | size | plus: 1 %}
          {% assign base_len = file.basename | size | minus: suffix_len %}
          {% assign base_caption = file.basename | slice: 0, base_len %}
        {% endif %}
        {% assign caption = base_caption | replace: "_", " " | replace: "-", " " %}
        <figure class="misc-gallery__item">
          <img
            class="misc-gallery__image img-fluid rounded z-depth-1"
            src="{{ file.path | relative_url }}"
            alt="{{ caption }}"
            loading="lazy"
          >
          <figcaption class="misc-gallery__caption">{{ caption }}</figcaption>
        </figure>
      {% endfor %}
    </div>
  {% else %}
    <p class="misc-gallery__empty">
      Add images to <code>{{ include.folder }}</code> and they will appear here automatically.
    </p>
  {% endif %}
</section>
